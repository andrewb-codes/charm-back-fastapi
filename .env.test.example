# FastAPI database connection used by the API and Alembic.
DATABASE_URL=postgresql+asyncpg://charm_user:charm_password@localhost:5432/charm_test

# JWT secret used by the FastAPI authentication flow.
JWT_SECRET=test-secret

# Streamlit API target for running the frontend outside Docker Compose.
STREAMLIT_API_URL=http://127.0.0.1:8000
