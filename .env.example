# Copy this file to .env for local development.

# FastAPI application settings.
APP_NAME='Charm API'
DEBUG=true
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# FastAPI database connection used by the API and Alembic.
DATABASE_URL=postgresql+asyncpg://charm_user:charm_password@postgres:5432/charm

# JWT settings used by the FastAPI authentication flow.
JWT_SECRET=change-this-secret-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_TTL_MINUTES=60

# Used by Streamlit to call the FastAPI backend when started locally.
STREAMLIT_API_URL=http://127.0.0.1:8000

# Docker Compose published ports.
API_PORT=8000
STREAMLIT_PORT=8501

# PostgreSQL container settings used by docker-compose.
POSTGRES_DB=charm
POSTGRES_USER=charm_user
POSTGRES_PASSWORD=charm_password
POSTGRES_PORT=5434
