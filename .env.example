# Copy this file to .env for local development.

# FastAPI database connection used by the API and Alembic.
DATABASE_URL=postgresql+asyncpg://charm_user:charm_password@postgres:5432/charm

# JWT secret used by the FastAPI authentication flow.
JWT_SECRET=change-this-secret-to-a-long-random-string

# Demo user created by the seed script.
DEMO_USER_ENABLED=false
DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=change-this-demo-password

# Synthetic users created by the seed script.
SYNTHETIC_USERS_ENABLED=false
SYNTHETIC_USERS_COUNT=100
SYNTHETIC_USERS_EMAIL_PREFIX=synthetic
SYNTHETIC_USERS_PASSWORD=change-this-synthetic-password

# Used by Streamlit to call the FastAPI backend inside Docker Compose.
STREAMLIT_API_URL=http://api:8000

# Docker Compose published ports.
API_PORT=8000
STREAMLIT_PORT=8501

# PostgreSQL container settings used by docker-compose.
POSTGRES_DB=charm
POSTGRES_USER=charm_user
POSTGRES_PASSWORD=charm_password
POSTGRES_PORT=5434
