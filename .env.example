# Copy this file to .env for local development.

# Application metadata and runtime mode.
APP_NAME='Charm API'
DEBUG=true

# Used by docker-compose to initialize the PostgreSQL container.
POSTGRES_DB=charm
POSTGRES_USER=charm_user
POSTGRES_PASSWORD=charm_password
POSTGRES_PORT=5434

# Used by docker-compose for the published API port.
API_PORT=8000

# Used by the API and Alembic to connect to PostgreSQL.
DATABASE_URL=postgresql+asyncpg://charm_user:charm_password@postgres:5432/charm

# Used by the API to sign and validate JWT access tokens.
JWT_SECRET=change-this-secret-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_TTL_MINUTES=60

# Comma-separated frontend origins allowed by the API CORS middleware.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
